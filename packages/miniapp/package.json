{
  "name": "@mingai/miniapp",
  "version": "0.1.0",
  "private": true,
  "description": "易有吉微信小程序",
  "templateInfo": {
    "name": "default",
    "typescript": true,
    "css": "sass"
  },
  "scripts": {
    "build:weapp": "taro build --type weapp",
    "build:weapp:prod": "taro build --type weapp --mode production",
    "dev:weapp": "taro build --type weapp --watch",
    "start": "npm run dev:weapp"
  },
  "browserslist": [
    "last 3 versions",
    "Android >= 4.1",
    "ios >= 8"
  ],
  "dependencies": {
    "@mingai/shared": "workspace:*",
    "taibu-core": "workspace:*",
    "@tarojs/components": "4.0.9",
    "@tarojs/helper": "4.0.9",
    "@tarojs/plugin-framework-react": "4.0.9",
    "@tarojs/plugin-platform-weapp": "4.0.9",
    "@tarojs/react": "4.0.9",
    "@tarojs/runtime": "4.0.9",
    "@tarojs/shared": "4.0.9",
    "@tarojs/taro": "4.0.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@babel/plugin-proposal-class-properties": "^7.18.0",
    "@babel/plugin-transform-runtime": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.24.0",
    "@babel/preset-typescript": "^7.24.0",
    "@babel/runtime": "^7.24.0",
    "@tarojs/cli": "4.0.9",
    "@tarojs/webpack5-runner": "4.0.9",
    "@types/react": "^18.3.0",
    "babel-preset-taro": "4.0.9",
    "react-refresh": "^0.14.0",
    "sass": "^1.77.0",
    "typescript": "^5.0.0",
    "webpack": "5.91.0"
  }
}
