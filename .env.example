# ##############################################################################
# 生产环境配置模板
# 复制此文件为 .env 并填入实际值
# ##############################################################################

# 基础环境配置
NODE_ENV=production

# Linux DO Connect OAuth
LINUXDO_CLIENT_ID=
LINUXDO_CLIENT_SECRET=

# MCP 服务配置
# 仅部署 MCP 时，生产环境建议至少配置 MCP_ALLOWED_ORIGINS（不要用 *）
# 注意：不要在变量赋值后写行尾注释（例如 `MCP_ALLOWED_HOSTS=  # ...`），否则在 Docker/Compose 下可能被当作变量值的一部分。
# 绑定地址，Docker 中用 0.0.0.0
MCP_HOST=0.0.0.0
# 逗号分隔的允许 Origin 白名单（浏览器请求必填，填 * 表示允许所有 Origin）
MCP_ALLOWED_ORIGINS=https://www.mingai.fun,https://mingai.fun
# 可选：逗号分隔的 Host 白名单
MCP_ALLOWED_HOSTS=
# 最大并发会话数
MCP_MAX_SESSIONS=1000
# 会话最大生命周期（默认 30 分钟）
MCP_SESSION_TTL_MS=1800000
# 会话空闲超时（默认 10 分钟）
MCP_SESSION_IDLE_MS=600000
# 每用户最大 SSE 并发数
MCP_MAX_SSE_PER_USER=3
# 反向代理后设为 true
MCP_TRUST_PROXY=true

# MCP OAuth 2.1
# JWT 签名密钥（至少 32 字符，必填，生产环境必须设置）
MCP_JWT_SECRET=
# OAuth issuer URL
MCP_ISSUER_URL=https://mcp.mingai.fun
# OAuth 授权页品牌站点地址（Logo / 注册 / 更多信息链接来源）
TAIBU_SITE_URL=https://www.mingai.fun
# 可选：额外 Access Token aud（逗号分隔）；系统始终允许 issuer 与 issuer/mcp
MCP_ALLOWED_TOKEN_AUDIENCES=
# Access token 有效期（秒），默认 1h
MCP_ACCESS_TOKEN_TTL=3600
# Refresh token 有效期（秒），默认 30d
MCP_REFRESH_TOKEN_TTL=2592000
# OAuth 调试日志开关（生产建议 false）
MCP_OAUTH_DEBUG=false

# 仅部署 MCP（docker-compose.mcp.yml）时，最小必填仅为 SUPABASE_URL + SUPABASE_ANON_KEY
# Supabase 配置
SUPABASE_URL=
SUPABASE_ANON_KEY=
# 专用服务端 Auth 管理密钥（第三方登录首次建号推荐必填，优先使用新的 secret key）
SUPABASE_SECRET_KEY=
# 完整服务端能力：系统管理员邮箱和密码
# 必填（完整服务端能力）：系统管理员邮箱
SUPABASE_SYSTEM_ADMIN_EMAIL=
# 必填（完整服务端能力）：系统管理员密码
SUPABASE_SYSTEM_ADMIN_PASSWORD=
# Edge Function 直连数据库（用于 create-vector-index）
SUPABASE_DB_URL=
# 内部 API 签名，用于向量索引（create-vector-index）与Chat跳过积分授权（自定义，可使用 openssl rand -hex 32 生成）
# 注意：该值需同时配置到 Web/MCP 运行环境与 Supabase Edge Function Secrets（同名 INTERNAL_API_SECRET 且值一致）
INTERNAL_API_SECRET=

# Github Actions（定时器）（自定义，可使用 openssl rand -hex 32 生成）
# 用于验证 GitHub Actions 定时任务请求
CRON_SECRET=your-cron-secret-key-here

# Dify 工作流：附件上传/搜索
DIFY_API_KEY=
DIFY_API_URL=https://api.dify.ai/v1

# 高德 Web 服务 API（出生地点解析为经度，用于真太阳时）
AMAP_WEB_SERVICE_KEY=

# AI 知识库
KNOWLEDGE_BASE_EMBEDDING_MODEL_ID=text-embedding-v4
KNOWLEDGE_BASE_RERANK_MODEL_ID=qwen3-rerank
VECTOR_SEARCH_ENABLED=false

# AI API - 统一网关
NEWAPI_BASE_URL=
NEWAPI_API_KEY=
OCTOPUS_BASE_URL=
OCTOPUS_API_KEY=

# DeepSeek API
# 文档: https://api-docs.deepseek.com/zh-cn/
# DeepSeek API 使用与 OpenAI 兼容的 API 格式
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 火山引擎 API
VOLC_API_KEY=

# Gemini API
GEMINI_API_KEY=

# AI 模型降级配置（JSON 格式）
MINGAI_FALLBACK_MODELS_JSON=

# 阿里云短信服务
# 文档: https://help.aliyun.com/zh/sms
# 获取步骤:
# 1. 登录阿里云控制台: https://ram.console.aliyun.com/
# 2. 创建 AccessKey ID 和 Secret: https://ram.console.aliyun.com/manage/ak
# 3. 开通短信服务: https://dysms.console.aliyun.com/
# 4. 创建短信签名和模板: https://dysms.console.aliyun.com/sign-template
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=
ALIYUN_SMS_REGION_ID=cn-hangzhou

# Web 服务端口配置
WEB_PORT=3000
MCP_PORT=3001

# 微信支付配置
# 文档: docs/WECHAT_PAY_SETUP.md
# 微信支付商户号（必填）
WECHAT_PAY_MCHID=
# 微信支付 AppID（必填，公众号/小程序/开放平台的 AppID）
WECHAT_PAY_APPID=
# APIv3 密钥（必填，32位随机字符串，商户平台设置）
WECHAT_PAY_API_V3_KEY=
# 商户 API 证书序列号（必填）
WECHAT_PAY_MCH_SERIAL_NO=
# 商户私钥内容（必填，apiclient_key.pem 的完整内容）
WECHAT_PAY_PRIVATE_KEY=
# 支付回调地址（必填，HTTPS，公网可访问）
WECHAT_PAY_NOTIFY_URL=https://yiyouji.zjsifan.com/api/membership/pay/callback
# H5 支付域名（可选，如使用 H5 支付）
WECHAT_PAY_H5_DOMAIN=yiyouji.zjsifan.com

# 微信小程序配置
# 小程序 AppID（如与公众号共用，填写相同值）
WECHAT_MINIAPP_APPID=wx314d6d3cfbd33e79
# 小程序 AppSecret（微信公众平台 → 开发管理 → 开发设置）
WECHAT_MINIAPP_SECRET=
# 小程序 CI 上传密钥（微信公众平台 → 开发管理 → 小程序代码上传）
WECHAT_MINIAPP_CI_PRIVATE_KEY=

# 本地开发模式配置（生产环境禁用）
USE_LOCAL_DB=false
