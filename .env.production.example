# ##############################################################################
# 生产环境配置文件（服务器部署专用）
# 
# 使用说明：
# 1. 复制此文件为 .env.local 或 .env.production
# 2. 填入所有必填项的实际值
# 3. 确保密钥安全，不要提交到 Git
#
# 生成时间: $(date '+%Y-%m-%d %H:%M:%S')
# ##############################################################################

# ==================== 基础环境配置 ====================
NODE_ENV=production

# ==================== Supabase 核心配置（⭐ 最关键）====================
# 从 Supabase Dashboard → Settings → API 获取
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_URL=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key-here
SUPABASE_SECRET_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-key-here

# 系统管理员账户（用于系统管理功能）
SUPABASE_SYSTEM_ADMIN_EMAIL=admin@example.com
SUPABASE_SYSTEM_ADMIN_PASSWORD=your-secure-password-here

# Edge Function 直连数据库 URL（可选，用于向量索引）
SUPABASE_DB_URL=postgresql://postgres:[password]@db.xxx.supabase.co:5432/postgres

# ==================== 内部API密钥（⭐ 必填）====================
# 用于向量索引和内部服务通信
# 生成方法: openssl rand -hex 32
INTERNAL_API_SECRET=your-generated-secret-key-min-32-chars

# GitHub Actions 定时任务验证密钥
CRON_SECRET=your-cron-secret-key-here

# ==================== AI API 配置（推荐配置）====================
# 统一 AI 网关（NewAPI / OneAPI）
NEWAPI_BASE_URL=https://api.newapi.com
NEWAPI_API_KEY=sk-your-newapi-key

# DeepSeek API（备用）
DEEPSEEK_API_KEY=sk-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Gemini API（备用）
GEMINI_API_KEY=AIzaSy-gemini-key

# 火山引擎 API（备用）
VOLC_API_KEY=volc-api-key

# ==================== 微信支付配置（⭐ 支付功能必填）====================
# 文档: docs/WECHAT_PAY_SETUP.md
WECHAT_PAY_MCHID=your-mchid
WECHAT_PAY_APPID=your-appid
WECHAT_PAY_API_V3_KEY=your-api-v3-key-32-chars
WECHAT_PAY_MCH_SERIAL_NO=your-serial-no
WECHAT_PAY_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhki...\n-----END PRIVATE KEY-----"
WECHAT_PAY_NOTIFY_URL=https://your-domain.com/api/membership/pay/callback
WECHAT_PAY_H5_DOMAIN=your-domain.com

# ==================== MCP 服务配置（如部署 MCP 服务）====================
MCP_HOST=0.0.0.0
MCP_ALLOWED_ORIGINS=https://www.mingai.fun,https://mingai.fun
MCP_JWT_SECRET=your-jwt-secret-min-32-chars
MCP_ISSUER_URL=https://mcp.mingai.fun
TAIBU_SITE_URL=https://www.mingai.fun

# ==================== 其他服务（可选）====================
# 阿里云短信服务（验证码发送）
ALIYUN_SMS_ACCESS_KEY_ID=your-access-key-id
ALIYUN_SMS_ACCESS_KEY_SECRET=your-access-key-secret
ALIYUN_SMS_SIGN_NAME=你的签名
ALIYUN_SMS_TEMPLATE_CODE=SMS_xxx
ALIYUN_SMS_REGION_ID=cn-hangzhou

# 高德地图 API（出生地经纬度转换）
AMAP_WEB_SERVICE_KEY=your-amap-key

# Dify 工作流（知识库附件处理）
DIFY_API_KEY=app-dify-key
DIFY_API_URL=https://api.dify.ai/v1

# Linux DO Connect OAuth（如果使用）
LINUXDO_CLIENT_ID=
LINUXDO_CLIENT_SECRET=

# ==================== 知识库配置（可选）====================
KNOWLEDGE_BASE_EMBEDDING_MODEL_ID=text-embedding-v4
KNOWLEDGE_BASE_RERANK_MODEL_ID=qwen3-rerank
VECTOR_SEARCH_ENABLED=false

# ==================== 端口配置 ====================
WEB_PORT=3000
MCP_PORT=3001

# ==================== 开发模式（生产环境必须 false）====================
USE_LOCAL_DB=false
